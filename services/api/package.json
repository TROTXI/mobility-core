{
  "name": "@trotxi/api",
  "version": "0.1.0",
  "private": true,
  "description": "Trotxi transactional API — auth, subscriptions, tokens, mobility.",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node --import ./dist/observability/tracing.live.js dist/server.js",
    "build": "tsup src/server.ts src/observability/tracing.live.ts --format esm --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.220.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.220.0",
    "@opentelemetry/instrumentation-fastify": "^0.57.0",
    "@opentelemetry/instrumentation-http": "^0.220.0",
    "@opentelemetry/instrumentation-ioredis": "^0.68.0",
    "@opentelemetry/instrumentation-pg": "^0.72.0",
    "@opentelemetry/instrumentation-pino": "^0.66.0",
    "@opentelemetry/instrumentation-runtime-node": "^0.33.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-logs": "^0.220.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "fastify": "^5.10.0",
    "fastify-plugin": "^6.0.0",
    "fastify-raw-body": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.2",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "pg": "^8.13.1",
    "prom-client": "^15.1.3",
    "sharp": "^0.35.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "eslint-plugin-jsdoc": "^63.0.12",
    "globals": "^15.14.0",
    "tsup": "^8.3.5",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^2.1.8"
  }
}
