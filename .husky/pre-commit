# Ensure dependencies are present, then run fast checks.
# Bypass in a pinch with `git commit --no-verify` (CI still enforces everything).

# A single workspace install covers every package.
if [ ! -d node_modules ] || [ pnpm-lock.yaml -nt node_modules/.modules.yaml ]; then
  echo "→ installing workspace dependencies ..."
  pnpm install || { echo "✗ pnpm install failed"; exit 1; }
fi

# Auto-format staged files (fast, per-file).
pnpm exec lint-staged || exit 1

# Only lint + typecheck the API when its source is actually staged.
if git diff --cached --name-only | grep -q '^services/api/.*\.\(ts\|js\)$'; then
  echo "→ linting + typechecking services/api ..."
  pnpm --filter @trotxi/api run lint && pnpm --filter @trotxi/api run typecheck || {
    echo "✗ pre-commit checks failed — fix the above, or 'git commit --no-verify' to bypass."
    exit 1
  }
fi
